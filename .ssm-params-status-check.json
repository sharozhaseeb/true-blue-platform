{"commands":["set -euo pipefail","cd /opt/trueblue","set -a; . ./.env; set +a","echo IMAGES","docker inspect true-blue-platform-app-1 --format \"APP={{.Config.Image}} HEALTH={{.State.Health.Status}} STATUS={{.State.Status}}\"","docker inspect true-blue-platform-nginx-1 --format \"NGINX={{.Config.Image}} HEALTH={{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}} STATUS={{.State.Status}}\"","docker inspect true-blue-platform-textract-worker-1 --format \"WORKER={{.Config.Image}} STATUS={{.State.Status}}\"","echo PORTS","docker compose -f docker-compose.prod.yml ps","echo LOCAL_HTTP","curl -s -o /dev/null -w \"%{http_code}\\n\" http://127.0.0.1/","curl -s -o /dev/null -w \"%{http_code}\\n\" http://127.0.0.1/login","echo NGINX_LOG_TAIL","docker compose -f docker-compose.prod.yml logs --tail=40 nginx","echo APP_LOG_TAIL","docker compose -f docker-compose.prod.yml logs --tail=60 app"]}

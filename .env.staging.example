# Database
DATABASE_URL=postgresql://trueblue:change-me@db:5432/trueblue?schema=public
POSTGRES_USER=trueblue
POSTGRES_PASSWORD=change-me
POSTGRES_DB=trueblue

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# App
NEXT_PUBLIC_APP_URL=https://staging.example.com
NODE_ENV=production
USE_SECURE_COOKIES=true
ENABLE_TEST_ENDPOINTS=false
APP_IMAGE=trueblue-platform-app:staging
MIGRATE_IMAGE=trueblue-platform-migrate:staging
WORKER_IMAGE=trueblue-platform-worker:staging

# AWS / S3
AWS_REGION=us-east-1
AWS_S3_BUCKET=trueblue-documents-536573256060-staging
AWS_S3_KMS_KEY_ID=arn:aws:kms:us-east-1:536573256060:key/8e4eec90-60cc-4e55-a7a8-dc9dc81b5958

# Textract structured document pipeline
AWS_TEXTRACT_REGION=us-east-1
TEXTRACT_FEATURE_SET=FORMS,TABLES,LAYOUT
TEXTRACT_RESULTS_BUCKET=trueblue-document-artifacts-536573256060-staging
TEXTRACT_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:536573256060:trueblue-textract-complete-staging
TEXTRACT_SQS_QUEUE_URL=https://queue.amazonaws.com/536573256060/trueblue-textract-jobs-staging
TEXTRACT_NOTIFICATION_ROLE_ARN=arn:aws:iam::536573256060:role/TrueBlueTextractPublishRole-staging
ENABLE_TEXTRACT_PIPELINE=false
ENABLE_BASE_DOCUMENT_DEBUG_API=false

# Pinecone
# PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE_PREFIX=trueblue
ENABLE_VECTOR_INDEXING=false
ENABLE_VECTOR_RETRIEVAL=false

# OpenAI
# OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
ENABLE_AI_CHAT=false

# Chat hardening
CHAT_USER_RATE_LIMIT_PER_MINUTE=60
CHAT_FIRM_RATE_LIMIT_PER_MINUTE=300

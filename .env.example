# Database
DATABASE_URL=postgresql://trueblue:trueblue_dev@localhost:5432/trueblue?schema=public

# Docker Compose Postgres (used by docker-compose.prod.yml)
POSTGRES_USER=trueblue
POSTGRES_PASSWORD=trueblue_dev
POSTGRES_DB=trueblue

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
USE_SECURE_COOKIES=false
ENABLE_TEST_ENDPOINTS=true
APP_IMAGE=trueblue-platform-app:local
MIGRATE_IMAGE=trueblue-platform-migrate:local
WORKER_IMAGE=trueblue-platform-worker:local

# AWS
# Local dev: set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY in an untracked local file.
# EC2 staging/prod: uses IAM Instance Profile (no credentials needed)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
AWS_S3_BUCKET=trueblue-documents-prod
AWS_S3_KMS_KEY_ID=

# Textract structured document pipeline
AWS_TEXTRACT_REGION=us-east-1
TEXTRACT_FEATURE_SET=FORMS,TABLES,LAYOUT
TEXTRACT_RESULTS_BUCKET=trueblue-document-artifacts-prod
TEXTRACT_SNS_TOPIC_ARN=
TEXTRACT_SQS_QUEUE_URL=
TEXTRACT_NOTIFICATION_ROLE_ARN=
ENABLE_TEXTRACT_PIPELINE=false
ENABLE_BASE_DOCUMENT_DEBUG_API=false

# Pinecone (fill when credentials arrive)
# PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE_PREFIX=trueblue
ENABLE_VECTOR_INDEXING=false
ENABLE_VECTOR_RETRIEVAL=false

# OpenAI (fill when credentials arrive)
# OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
ENABLE_AI_CHAT=false

# Chat hardening
CHAT_USER_RATE_LIMIT_PER_MINUTE=60
CHAT_FIRM_RATE_LIMIT_PER_MINUTE=300
